        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Trace-driven exploration of operator hot paths via the Tempo datasource. Pivot from runs.json by copying a trace_id from operator logs into the Trace ID input.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": ["renovate-operator"],
      "targetBlank": false,
      "title": "Other dashboards",
      "tooltip": "",
      "type": "dashboards",
      "url": ""
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "tempo", "uid": "${DS_TEMPO}"},
      "description": "Search Tempo for operator spans. The default service.name in main.go is 'renovate-operator' (override via tracing.serviceName in chart values).",
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "datasource": {"type": "tempo", "uid": "${DS_TEMPO}"},
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "operator": "=",
              "scope": "resource",
              "tag": "service.name",
              "value": ["renovate-operator"],
              "valueType": "string"
            }
          ],
          "limit": 50,
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent operator traces",
      "type": "table"
    },
    {
      "datasource": {"type": "tempo", "uid": "${DS_TEMPO}"},
      "description": "Paste a trace_id (from operator log line, e.g. logs.json) here.",
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 14},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "tempo", "uid": "${DS_TEMPO}"},
          "queryType": "traceql",
          "query": "${trace_id}",
          "refId": "A"
        }
      ],
      "title": "Trace by ID",
      "type": "traces"
    }
  ],
  "refresh": "",
  "schemaVersion": 39,
  "tags": ["renovate-operator"],

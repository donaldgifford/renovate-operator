{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operator and worker log exploration via Loki. Pre-set queries scope to the renovate-operator label and let you filter by scan/platform/level. The trace_id field is exposed as a derived field — click it to jump into traces.json.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "description": "Operator pod logs. Filter by scan/platform/level via the variables. JSON log shape is fixed by zap; trace_id is attached when a span is recording.",
      "gridPos": {"h": 16, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "expr": "{app_kubernetes_io_name=\"renovate-operator\", namespace=~\"$namespace\"} | json | level=~\"$level\" | scan=~\"$scan\" | platform=~\"$platform\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Operator logs",
      "type": "logs"
    },
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "description": "Worker pod logs (Renovate CLI output). Workers run in the same namespace as the RenovateRun.",
      "gridPos": {"h": 16, "w": 24, "x": 0, "y": 16},
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "expr": "{job=~\"renovate.*\", namespace=~\"$namespace\"}",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Worker logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["renovate-operator"],
  "templating": {
    "list": [
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
        "definition": "label_values({app_kubernetes_io_name=\"renovate-operator\"}, namespace)",
        "includeAll": true,
        "label": "namespace",
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": "label_values({app_kubernetes_io_name=\"renovate-operator\"}, namespace)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {"selected": false, "text": "All", "value": "$__all"},
        "includeAll": true,
        "label": "level",
        "multi": true,
        "name": "level",
        "options": [
          {"selected": true, "text": "All", "value": "$__all"},
          {"selected": false, "text": "debug", "value": "debug"},
          {"selected": false, "text": "info", "value": "info"},
          {"selected": false, "text": "warn", "value": "warn"},
          {"selected": false, "text": "error", "value": "error"}
        ],
        "query": "debug,info,warn,error",
        "queryValue": "",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "includeAll": true,
        "label": "scan",
        "multi": true,
        "name": "scan",
        "options": [],
        "query": ".*",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "includeAll": true,
        "label": "platform",
        "multi": true,
        "name": "platform",
        "options": [],
        "query": ".*",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",

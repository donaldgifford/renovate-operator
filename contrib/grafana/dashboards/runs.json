{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "RenovateRun lifecycle: active count, durations, success/failure ratio, shard count.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Currently non-terminal RenovateRuns by scan/platform.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(renovate_operator_active_runs{scan=~\"$scan\", platform=~\"$platform\"}) by (scan, platform)",
          "legendFormat": "{{scan}} / {{platform}}",
          "refId": "A"
        }
      ],
      "title": "Active runs",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Run terminal transitions (succeeded vs failed).",
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(renovate_operator_runs_total{scan=~\"$scan\", platform=~\"$platform\"}[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Run rate by result",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "p50/p95/p99 RenovateRun end-to-end duration.",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum(rate(renovate_operator_run_duration_seconds_bucket{scan=~\"$scan\", platform=~\"$platform\"}[5m])) by (le, scan, platform))",
          "legendFormat": "p50 {{scan}} / {{platform}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum(rate(renovate_operator_run_duration_seconds_bucket{scan=~\"$scan\", platform=~\"$platform\"}[5m])) by (le, scan, platform))",
          "legendFormat": "p95 {{scan}} / {{platform}}",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum(rate(renovate_operator_run_duration_seconds_bucket{scan=~\"$scan\", platform=~\"$platform\"}[5m])) by (le, scan, platform))",
          "legendFormat": "p99 {{scan}} / {{platform}}",
          "refId": "C"
        }
      ],
      "title": "Run duration (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Discovery-phase duration. p95 alone — the discover step is short, so p50/p99 add little signal.",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum(rate(renovate_operator_discovery_duration_seconds_bucket{scan=~\"$scan\", platform=~\"$platform\"}[5m])) by (le, scan, platform))",
          "legendFormat": "p95 {{scan}} / {{platform}}",
          "refId": "A"
        }
      ],
      "title": "Discovery duration (p95)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Shard count of the most recent Run (from sharding builder output).",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "renovate_run_shard_count{scan=~\"$scan\", platform=~\"$platform\"}",
          "legendFormat": "{{scan}} / {{platform}}",
          "refId": "A"
        }
      ],
      "title": "Shard count (latest run)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Failures: discovery errors and shard failures.",
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 6,
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(renovate_operator_discovery_errors_total{scan=~\"$scan\", platform=~\"$platform\"}[5m])) by (scan, platform)",
          "legendFormat": "discovery errors {{scan}} / {{platform}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(renovate_operator_shards_failed_total{scan=~\"$scan\", platform=~\"$platform\"}[5m])) by (scan, platform)",
          "legendFormat": "shard failures {{scan}} / {{platform}}",
          "refId": "B"
        }
      ],
      "title": "Discovery + shard failures",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["renovate-operator"],
  "templating": {
    "list": [
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(renovate_operator_runs_total, scan)",
        "includeAll": true,
        "label": "scan",
        "multi": true,
        "name": "scan",
        "options": [],
        "query": {"qryType": 1, "query": "label_values(renovate_operator_runs_total, scan)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(renovate_operator_runs_total{scan=~\"$scan\"}, platform)",
        "includeAll": true,
        "label": "platform",
        "multi": true,
        "name": "platform",
        "options": [],
        "query": {"qryType": 1, "query": "label_values(renovate_operator_runs_total{scan=~\"$scan\"}, platform)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Renovate Operator — Runs",
  "uid": "renovate-operator-runs",
  "version": 1,
  "weekStart": "",
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ]
}
